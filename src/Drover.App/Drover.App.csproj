<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
		<UseWindowsForms>true</UseWindowsForms>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
		<RootNamespace>Drover.App</RootNamespace>
		<AssemblyName>Drover.App</AssemblyName>
		<ApplicationIcon>Resources\Icons\drover-idle.ico</ApplicationIcon>
		<Version>0.1.0</Version>
		<StartupObject>Drover.App.Program</StartupObject>
	</PropertyGroup>

	<ItemGroup>
		<Using Remove="System.Windows.Forms" />
		<Using Remove="System.Drawing" />
	</ItemGroup>

	<!-- Suppress the SDK's auto-generated Main so Program.Main can run Velopack
	     hooks before WPF spins up. App.xaml is still compiled (as a Page) so
	     InitializeComponent() works as usual. -->
	<ItemGroup>
		<ApplicationDefinition Remove="App.xaml" />
		<Page Include="App.xaml" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
		<PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.7" />
		<PackageReference Include="Microsoft.Terminal.Wpf" Version="1.24.260303001" />
		<PackageReference Include="Microsoft.Toolkit.Uwp.Notifications" Version="7.1.3" />
		<PackageReference Include="AvalonEdit" Version="6.3.1.120" />
		<PackageReference Include="Microsoft.Windows.Console.ConPTY" Version="1.23.251216003" />
		<PackageReference Include="SharpVectors" Version="1.8.4" />
		<PackageReference Include="Velopack" Version="0.0.1298" />
	</ItemGroup>
	<ItemGroup>
		<Content Include="$(MSBuildThisFileDirectory)..\..\References\Microsoft.Terminal.Control.dll">
			<Link>Microsoft.Terminal.Control.dll</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<Target Name="VerifyTerminalControlPresent" BeforeTargets="PrepareForBuild">
		<Error Condition="!Exists('$(MSBuildThisFileDirectory)..\..\References\Microsoft.Terminal.Control.dll')"
		       Text="Missing References\Microsoft.Terminal.Control.dll. Download the latest Microsoft.WindowsTerminal_*_x64.zip from https://github.com/microsoft/terminal/releases, extract Microsoft.Terminal.Control.dll, and place it in the repo's References\ folder." />
	</Target>

	<ItemGroup>
		<Resource Include="Resources\Icons\drover-idle.ico" />
		<Resource Include="Resources\Icons\drover-working.ico" />
		<Resource Include="Resources\Icons\drover-attention.ico" />
		<Resource Include="Resources\Icons\drover-inactive.ico" />
		<Resource Include="Resources\CheatSheet.md" />
		<Resource Include="Resources\WhatsNew.md" />
		<Resource Include="Resources\FileIcons\*.svg" />
	</ItemGroup>
</Project>
