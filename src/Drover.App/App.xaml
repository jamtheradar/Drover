<Application x:Class="Drover.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="Chrome.Background" Color="#1e1e1e" />
                    <SolidColorBrush x:Key="Chrome.Panel" Color="#252526" />
                    <SolidColorBrush x:Key="Chrome.Border" Color="#333333" />
                    <SolidColorBrush x:Key="Chrome.Text" Color="#dddddd" />
                    <SolidColorBrush x:Key="Chrome.TextMuted" Color="#888888" />
                    <SolidColorBrush x:Key="Chrome.Accent" Color="#007acc" />
                    <SolidColorBrush x:Key="Chrome.AttentionIdle" Color="#4ec9b0" />
                    <SolidColorBrush x:Key="Chrome.AttentionWorking" Color="#dcdcaa" />
                </ResourceDictionary>
                <ResourceDictionary Source="Themes/Drover.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
