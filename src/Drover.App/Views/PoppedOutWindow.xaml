<Window x:Class="Drover.App.Views.PoppedOutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, FallbackValue='Drover tab'}"
        Height="700" Width="1100"
        Background="{StaticResource Chrome.Background}"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="{StaticResource Chrome.Panel}"
                BorderBrush="{StaticResource Chrome.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="10,0">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding Title, FallbackValue='tab'}"
                           Foreground="{StaticResource Chrome.Text}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <Button DockPanel.Dock="Right"
                        Content="Reattach"
                        Padding="10,2"
                        Margin="8,4"
                        Click="Reattach_Click" />
            </DockPanel>
        </Border>
        <Grid x:Name="Host" Grid.Row="1" />
    </Grid>
</Window>
