<Window x:Class="Drover.App.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename tab" Height="140" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Chrome.Panel}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Tab name" Foreground="{StaticResource Chrome.Text}" Margin="0,0,0,6" />
        <TextBox   Grid.Row="1" x:Name="NameBox" Padding="4" VerticalContentAlignment="Center" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="12,4" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="OK"     Padding="12,4" IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
