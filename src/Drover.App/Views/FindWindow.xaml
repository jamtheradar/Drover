<Window x:Class="Drover.App.Views.FindWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find in scrollback"
        Width="720" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Chrome.Panel}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="HeaderText"
                   Foreground="{StaticResource Chrome.TextMuted}"
                   FontSize="11" Margin="0,0,0,6" />
        <TextBox   Grid.Row="1" x:Name="QueryBox" Padding="6" FontSize="13"
                   TextChanged="Query_Changed"
                   PreviewKeyDown="Query_PreviewKeyDown" />
        <ListBox   Grid.Row="2" x:Name="Results" Margin="0,8,0,0"
                   Background="{StaticResource Chrome.Background}"
                   Foreground="{StaticResource Chrome.Text}"
                   FontFamily="Cascadia Code, Consolas"
                   FontSize="12"
                   MouseDoubleClick="Results_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding LineNumber}"
                                   Foreground="{StaticResource Chrome.TextMuted}"
                                   Margin="0,0,10,0" MinWidth="40" TextAlignment="Right" />
                        <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock Grid.Row="3" x:Name="StatusLine"
                   Foreground="{StaticResource Chrome.TextMuted}"
                   FontSize="11" Margin="0,6,0,0" />
    </Grid>
</Window>
