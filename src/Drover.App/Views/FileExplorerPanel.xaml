<UserControl x:Class="Drover.App.Views.FileExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:Drover.App.Models"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             Background="{StaticResource Chrome.Panel}"
             Foreground="{StaticResource Chrome.Text}"
             KeyboardNavigation.TabNavigation="Local">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="FxIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Chrome.Text}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface.ControlHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Expander chevron — small triangle rotates on expand. Dark-theme colour;
             default WPF chevron is system-Windows light grey and reads black-on-black. -->
        <Style x:Key="FxExpander" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="2">
                            <Path x:Name="Arrow"
                                  Fill="{StaticResource Chrome.TextMuted}"
                                  Data="M 0,0 L 4,4 L 0,8 Z"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource Chrome.Text}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource Chrome.Text}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeViewItem template: dark surface, hover/selection use chrome tokens
             (WPF default uses SystemColors.HighlightBrush which is Windows-blue). -->
        <Style x:Key="FxTreeViewItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Chrome.Text}" />
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="Expander"
                                          Grid.Column="0"
                                          Style="{StaticResource FxExpander}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press" />
                            <Border x:Name="Bd"
                                    Grid.Column="1"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1" Grid.Column="1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface.Hover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface.SelectedInactive}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsSelectionActive" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface.Selected}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type m:FileNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <svgc:SvgViewbox Width="14" Height="14"
                                 Margin="0,0,6,0"
                                 VerticalAlignment="Center"
                                 Source="{Binding IconUri}" />
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource Chrome.Border}" BorderThickness="0,0,0,1" Padding="10,8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource FxIconButton}"
                            Command="{Binding RefreshFileExplorerCommand}"
                            ToolTip="Reload tree (F5)"
                            Content="↻" />
                    <Button Style="{StaticResource FxIconButton}"
                            Click="OpenInExplorer_Click"
                            ToolTip="Open project root in Windows Explorer"
                            Content="🗁" />
                </StackPanel>
                <TextBlock Text="Files"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Chrome.TextMuted}" />
            </DockPanel>
        </Border>

        <!-- Tree -->
        <TreeView x:Name="Tree"
                  Grid.Row="1"
                  ItemsSource="{Binding FileExplorerRoots}"
                  ItemContainerStyle="{StaticResource FxTreeViewItem}"
                  Background="Transparent"
                  Foreground="{StaticResource Chrome.Text}"
                  BorderThickness="0"
                  KeyDown="Tree_KeyDown"
                  MouseDoubleClick="Tree_MouseDoubleClick"
                  PreviewMouseRightButtonDown="Tree_PreviewMouseRightButtonDown">
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Insert @path at prompt" Click="InsertAtPath_Click" />
                    <MenuItem Header="Open" Click="OpenNode_Click" />
                    <MenuItem Header="Reveal in Explorer" Click="RevealNode_Click" />
                    <Separator />
                    <MenuItem Header="Copy full path" Click="CopyFullPath_Click" />
                    <MenuItem Header="Copy relative path" Click="CopyRelPath_Click" />
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>

        <!-- Status footer -->
        <Border Grid.Row="2" BorderBrush="{StaticResource Chrome.Border}" BorderThickness="0,1,0,0" Padding="10,6">
            <TextBlock Text="{Binding FileExplorerStatusText}"
                       Foreground="{StaticResource Chrome.TextMuted}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</UserControl>
