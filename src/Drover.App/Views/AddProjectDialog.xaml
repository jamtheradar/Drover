<Window x:Class="Drover.App.Views.AddProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project"
        Height="640" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{StaticResource Chrome.Panel}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Foreground="{StaticResource Chrome.Text}" VerticalAlignment="Center" Margin="0,0,12,8" />
        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="NameBox" Margin="0,0,0,8" Padding="4" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" Foreground="{StaticResource Chrome.Text}" VerticalAlignment="Center" Margin="0,0,12,8" />
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="PathBox" Margin="0,0,8,8" Padding="4" />
        <Button    Grid.Row="1" Grid.Column="2" Content="Browse…" Margin="0,0,0,8" Padding="10,4" Click="Browse_Click" />

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Kind" Foreground="{StaticResource Chrome.Text}" VerticalAlignment="Center" Margin="0,0,12,0" />
            <RadioButton x:Name="KindClaude"       Content="Claude"        IsChecked="True" Foreground="{StaticResource Chrome.Text}" Margin="0,0,12,0" />
            <RadioButton x:Name="KindClaudeDirect" Content="Claude (direct)"                Foreground="{StaticResource Chrome.Text}" Margin="0,0,12,0"
                         ToolTip="Launch claude.exe straight from CreateProcess — no pwsh wrapper. Faster startup; the tab closes when claude exits (no shell stays open)." />
            <RadioButton x:Name="KindPwsh"         Content="pwsh"                           Foreground="{StaticResource Chrome.Text}" />
        </StackPanel>

        <Expander Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                  Header="Advanced"
                  Foreground="{StaticResource Chrome.TextMuted}"
                  IsExpanded="False">
            <Grid Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Command" Foreground="{StaticResource Chrome.Text}" VerticalAlignment="Center" Margin="0,0,12,6" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CommandBox" Margin="0,0,0,6" Padding="4"
                           ToolTip="Defaults: 'claude' for Claude projects, nothing for pwsh." />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Args" Foreground="{StaticResource Chrome.Text}" VerticalAlignment="Center" Margin="0,0,12,6" />
                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ArgsBox" Margin="0,0,0,6" Padding="4"
                           ToolTip="Appended after command, e.g. '--model opus'." />

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Model" Foreground="{StaticResource Chrome.Text}" VerticalAlignment="Center" Margin="0,0,12,6" />
                <ComboBox  Grid.Row="8" Grid.Column="1" x:Name="ModelBox" Margin="0,0,0,6" Padding="4"
                           IsEditable="True"
                           ToolTip="Per-project --model override. Overrides the global default model. Ignored if --model is already in Args." />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Plans folder" Foreground="{StaticResource Chrome.Text}" VerticalAlignment="Center" Margin="0,0,12,6" />
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                    <TextBox x:Name="PlansFolderBox" Padding="4"
                             ToolTip="Relative to project root. Defaults to .claude/plans/. Drover also picks up PLAN.md at the project root." />
                    <TextBlock Text="Relative to project root. Defaults to .claude/plans/. Drover also reads PLAN.md at the root."
                               Foreground="{StaticResource Chrome.TextMuted}"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                </StackPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Tab color" Foreground="{StaticResource Chrome.Text}" VerticalAlignment="Center" Margin="0,0,12,6" />
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,6">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Right"
                                x:Name="TabColorSwatch"
                                Width="28" Height="22"
                                Margin="6,0,0,0"
                                BorderBrush="{StaticResource Chrome.Border}"
                                BorderThickness="1"
                                Background="Transparent" />
                        <TextBox x:Name="TabColorBox" Padding="4"
                                 TextChanged="TabColorBox_TextChanged"
                                 ToolTip="Hex color for this project's tab background, e.g. #3D7EFF. Leave blank for default." />
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="" Width="22" Height="18" Margin="0,0,4,0" Click="TabColorPreset_Click" Tag="#3D7EFF" Background="#3D7EFF" BorderThickness="0" />
                        <Button Content="" Width="22" Height="18" Margin="0,0,4,0" Click="TabColorPreset_Click" Tag="#7EC07E" Background="#7EC07E" BorderThickness="0" />
                        <Button Content="" Width="22" Height="18" Margin="0,0,4,0" Click="TabColorPreset_Click" Tag="#FFB454" Background="#FFB454" BorderThickness="0" />
                        <Button Content="" Width="22" Height="18" Margin="0,0,4,0" Click="TabColorPreset_Click" Tag="#E06C75" Background="#E06C75" BorderThickness="0" />
                        <Button Content="" Width="22" Height="18" Margin="0,0,4,0" Click="TabColorPreset_Click" Tag="#C586C0" Background="#C586C0" BorderThickness="0" />
                        <Button Content="" Width="22" Height="18" Margin="0,0,8,0" Click="TabColorPreset_Click" Tag="#5BBFAA" Background="#5BBFAA" BorderThickness="0" />
                        <Button Content="Clear" Padding="6,0" Click="TabColorClear_Click" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="Environment (KEY=VALUE per line)"
                           Foreground="{StaticResource Chrome.Text}"
                           Margin="0,8,0,4" />
                <TextBox   Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                           x:Name="EnvBox"
                           MinHeight="80"
                           AcceptsReturn="True"
                           VerticalScrollBarVisibility="Auto"
                           FontFamily="Cascadia Code, Consolas"
                           Padding="4" />

                <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="Launch command (raw — overrides everything above)"
                           Foreground="{StaticResource Chrome.Text}"
                           Margin="0,12,0,4" />
                <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2">
                    <TextBox x:Name="LaunchCommandBox" Padding="4"
                             FontFamily="Cascadia Code, Consolas"
                             ToolTip="Passed directly to ConPTY. Bypasses Kind/Command/Args/Env/Resume. You own shell, cwd, env. Examples: 'cmd.exe /K &quot;cd /d C:\path &amp;&amp; claude&quot;', 'claude' (no shell), '&quot;C:\Program Files\Git\bin\bash.exe&quot; -i -c &quot;cd /c/path &amp;&amp; claude&quot;'." />
                    <TextBlock Text="For shell-latency experiments. Bypasses Kind/Command/Args/Env. Leave blank to use the standard pwsh launch."
                               Foreground="{StaticResource Chrome.TextMuted}"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Expander>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="12,4" Margin="0,0,8,0" IsCancel="True" />
            <Button x:Name="SubmitButton" Content="Add"    Padding="12,4" IsDefault="True" Click="Add_Click" />
        </StackPanel>
    </Grid>
</Window>
