<Window x:Class="Drover.App.Views.WhatsNewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's new in Drover"
        Width="640" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Chrome.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Chrome.Panel}"
                BorderBrush="{StaticResource Chrome.Border}"
                BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel>
                <TextBlock Text="What's new" FontSize="18"
                           Foreground="{StaticResource Chrome.Text}" FontWeight="SemiBold" />
                <TextBlock x:Name="SubtitleText" FontSize="11"
                           Foreground="{StaticResource Chrome.TextMuted}"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <FlowDocumentScrollViewer Grid.Row="1"
                                  x:Name="Viewer"
                                  Padding="24,12"
                                  Background="Transparent"
                                  IsToolBarVisible="False"
                                  VerticalScrollBarVisibility="Auto" />

        <Border Grid.Row="2" Background="{StaticResource Chrome.Panel}"
                BorderBrush="{StaticResource Chrome.Border}"
                BorderThickness="0,1,0,0" Padding="14,10">
            <Button Content="Got it"
                    Click="Close_Click"
                    HorizontalAlignment="Right"
                    Padding="14,5"
                    IsDefault="True" IsCancel="True" />
        </Border>
    </Grid>
</Window>
